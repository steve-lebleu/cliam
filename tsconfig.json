{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "./dist",
    "removeComments": true,
    "sourceMap": false,
    "lib": ["ES2022"],
    "declaration": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@decorators/*": ["src/types/decorators/*"],
      "@enums/*": ["src/types/enums/*"],
      "@interfaces/*": ["src/types/interfaces/*"],
      "@schemas/*": ["src/types/schemas/*"],
      "@typings/*": ["src/types/types/*"],
      "@services/*": ["src/services/*"],
      "@classes/*": ["src/classes/*"],
      "@transporters/*": ["src/transporters/*"],
      "@validations/*": ["src/validations/*"],
      "@utils/*": ["src/utils/*"]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "test"
  ]
}
